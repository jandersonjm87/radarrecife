# ============================================================
#  .env.example — Radar Recife
#  Copie para .env e preencha os valores reais.
#  NUNCA commite o arquivo .env no repositório.
# ============================================================

# Aplicacao
APP_NAME=Radar Recife
APP_VERSION=1.0.0
DEBUG=false

# CORS
# Desenvolvimento: ALLOWED_ORIGINS=*
# Producao: ALLOWED_ORIGINS=https://seu-dominio.railway.app
ALLOWED_ORIGINS=*

# Cache TTL em segundos (opcional — valores padrao ja configurados)
CACHE_CLIMA_TTL=300
CACHE_ELNINO_TTL=86400
CACHE_MARINE_TTL=1800
CACHE_NOTICIAS_TTL=600
